---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const publishDate = entry.data.date?.toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const youtubeVideoId = entry.data.youtubeId;
const disqusShortname = "misterdatos";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<Layout title={entry.data.title}>
  <main class="post-container">

    <article class="post-content">
      <header class="post-header">
        <div class="category-badge">{entry.data.categories?.[0] || "Tech"}</div>
        <h1 class="post-title">{entry.data.title}</h1>

        <div class="post-meta">
          <span class="meta-item">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"
              ></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
                x1="8"
                y1="2"
                x2="8"
                y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg
            >
            {publishDate}
          </span>
          <span class="meta-item">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
              ></path><circle cx="12" cy="7" r="4"></circle></svg
            >
            {entry.data.author || "MisterDatos"}
          </span>
        </div>

        {
          entry.data.image && (
            <div class="image-wrapper">
              <Image
                src={entry.data.image}
                alt={entry.data.title}
                class="featured-image"
                loading="eager"
              />
            </div>
          )
        }
      </header>

      <section class="prose">
        <Content />
      </section>

      {
        youtubeVideoId && (
          <section class="video-section">
            <h2 class="section-title">Video Relacionado</h2>
            <div class="video-responsive">
              <iframe
                src={`https://www.youtube.com/embed/${youtubeVideoId}`}
                title="YouTube video player"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                loading="lazy"
              />
            </div>
          </section>
        )
      }

      <section class="comments-section">
        <h2 class="section-title">Comentarios</h2>
        <div id="disqus_thread"></div>
      </section>
    </article>
  </main>
</Layout>

<script is:inline define:vars={{ disqusShortname, url: canonicalURL.href, id: entry.slug }}>
  const commentsSection = document.getElementById('disqus_thread');

  if (commentsSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {

        if (entry.isIntersecting) {
          loadDisqus();
          observer.disconnect();
        }
      });
    }, { rootMargin: '300px' });

    observer.observe(commentsSection);
  }

  function loadDisqus() {
    window.disqus_config = function () {
      this.page.url = url;
      this.page.identifier = id;
    };

    var d = document, s = d.createElement('script');
    s.src = 'https://' + disqusShortname + '.disqus.com/embed.js';
    s.setAttribute('data-timestamp', +new Date());
    (d.head || d.body).appendChild(s);
  }
</script>

<style>
  .post-container {
    position: relative;
    margin: 0 auto;
    padding: 2rem 2rem;
    min-height: 100vh;
  }

  .post-title {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    line-height: 1.1;
    margin-top: 1rem;
    margin-bottom: 1rem;
    color: var(--color-white);
    font-family: var(--font-main);
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    color: #8892b0;
    font-size: 1rem;
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .image-wrapper {
    margin: 1rem;
  }

  .featured-image {
    width: 100%;
    height: auto;
    border-radius: 12px;
    display: block;
  }

  .prose {
    color: #cbd5e1;
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1rem;
    margin-top: 1rem;
  }

  .prose :global(h2) {
    color: var(--color-accent);
    font-family: var(--font-main);
    margin-top: 2rem;
    font-size: 1.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(code) {
    background: rgba(145, 70, 255, 0.1);
    color: var(--color-accent);
    padding: 0.25rem 0.25rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .category-badge {
    color: var(--color-accent);
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.75rem;
  }

  .section-title {
    color: var(--color-white);
    font-family: var(--font-main);
    font-size: 1.75rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .video-responsive {
    overflow: hidden;
    padding-bottom: 56.25%;
    position: relative;
    height: 0;
    border-radius: 12px;
    background: #000;
  }

  .video-responsive iframe {
    left: 0;
    top: 0;
    height: 100%;
    width: 100%;
    position: absolute;
    border: 0;
  }

  .tags-container {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .tag {
    font-size: 0.9rem;
    color: var(--color-accent);
    opacity: 0.7;
  }

  .comments-section {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  @media (min-width: 768px) {
    .post-container {
      padding-top: 1rem;
    }
  }
</style>