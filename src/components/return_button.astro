---
interface Props {
    href?: string;
    icon?: string;
    className?: string;
    arialabel?: string;
}

const { href = '/', icon = "fa-arrow-left", className = "return-button", arialabel = "Go to homepage"} = Astro.props;
---

<a href={href} class={className} aria-label={arialabel}>
    <i class={`fa-solid ${icon}`}></i>
</a>

<style>
    .return-button {
        position: fixed;
        top: 20px;
        left: 20px;
        width: 50px;
        height: 50px;
        background: linear-gradient(
            135deg,
            var(--color-accent),
            var(--color-primary)
        );
        color: var(--color-white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        text-decoration: none;
        transition: var(--transition);
        z-index: 1000;
    }

    .return-button:hover {
        transform: scale(1.1);
        color: var(--color-white);
    }

    .return-button:active {
        transform: scale(0.9);
    }
</style>