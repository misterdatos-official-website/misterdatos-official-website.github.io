---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const allPosts = await getCollection("blog");

const recentPosts = allPosts
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 10);
---

<section class="blog-section" id="blog">
    <div class="blog-header">
        <h2 class="section-title">Últimas Novedades</h2>
        <div class="slider-controls">
            <button id="prevBtn" class="control-btn" aria-label="Anterior"
                >❮</button
            >
            <button id="nextBtn" class="control-btn" aria-label="Siguiente"
                >❯</button
            >
        </div>
    </div>

    <div class="scroll-container" id="slider">
        <div class="posts-slider">
            {
                recentPosts.map((post) => (
                    <a href={`/blog/${post.slug}`} class="post-card-link">
                        <article class="post-card">
                            {post.data.image && (
                                <div class="post-image">
                                    <Image
                                        src={post.data.image}
                                        alt={post.data.title}
                                        loading={"lazy"}
                                        decoding={"async"}
                                        quality={"high"}
                                    />
                                </div>
                            )}
                            <div class="post-info">
                                <time datetime={post.data.date.toISOString()}>
                                    {post.data.date.toLocaleDateString(
                                        "es-ES",
                                        {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        },
                                    )}
                                </time>
                                <h3>{post.data.title}</h3>
                                <p>{post.data.description}</p>
                            </div>
                        </article>
                    </a>
                ))
            }
        </div>
    </div>

    <div class="view-all-container">
        <a href="/blog" class="btn-all">Ver todas las publicaciones</a>
    </div>
</section>

<script>
    const slider = document.getElementById("slider");
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");

    if (slider && prevBtn && nextBtn) {
        nextBtn.addEventListener("click", () => {
            slider.scrollBy({ left: 350, behavior: "smooth" });
        });
        prevBtn.addEventListener("click", () => {
            slider.scrollBy({ left: -350, behavior: "smooth" });
        });
    }
</script>

<style>
    .blog-section {
        padding: 1rem 1rem;
        max-width: 1200px;
        margin: 0px auto;
        color: white;
        background-color: var(--color-dark);
        scroll-margin-top: 80px;
    }

    .blog-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .section-title {
        font-size: 1.25rem;
        margin: 0;
        color: #ffffff;
    }

    .slider-controls {
        display: none;
        gap: 0.5rem;
    }

    .control-btn {
        background: rgba(167, 139, 250, 0.1);
        border: 1px solid rgba(167, 139, 250, 0.3);
        color: #a78bfa;
        padding: 0.5rem 0.8rem;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        -webkit-tap-highlight-color: transparent;
        outline: none;
    }

    .control-btn:hover {
        background: #8b5cf6;
        color: white;
    }

    .scroll-container {
        width: 100%;
        overflow-x: auto;
        scroll-behavior: smooth;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding: 1rem 0 1rem 0;
    }

    .scroll-container::-webkit-scrollbar {
        display: none;
    }

    .posts-slider {
        display: flex;
        gap: 1.5rem;
    }

    .post-card-link {
        text-decoration: none;
        flex: 0 0 280px;
        display: block;
        -webkit-tap-highlight-color: transparent;
        outline: none;
    }

    .post-card {
        background: rgba(28, 10, 27, 0.6);
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition:
            transform 0.3s ease,
            border-color 0.3s ease,
            filter 0.2s ease,
            box-shadow 0.3s ease;
        height: 100%;
    }

    .post-card:active {
        transform: scale(0.97);
        border-color: #a78bfa;
        filter: brightness(0.8);
        box-shadow: 0 0 15px rgba(167, 139, 250, 0.3);
    }

    .post-card:hover {
        transform: translateY(-5px);
    }

    .post-image img {
        width: 100%;
        height: 180px;
        object-fit: cover;
    }

    .post-info {
        padding: 1.5rem;
    }

    .post-info time {
        display: block;
        font-size: 0.8rem;
        color: #a78bfa;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    .post-info h3 {
        font-size: 1.15rem;
        margin-bottom: 0.75rem;
        color: white;
        line-height: 1.3;
    }

    .post-info p {
        font-size: 0.9rem;
        opacity: 0.8;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        vertical-align: middle;
        overflow: hidden;
        color: #ddd;
    }

    .view-all-container {
        display: flex;
        justify-content: center;
    }

    .btn-all {
        padding: 1rem 1rem;
        border: 2px solid #8b5cf6;
        border-radius: 10px;
        color: white;
        text-decoration: none;
        font-weight: bold;
        transition: all 0.3s ease;
        -webkit-tap-highlight-color: transparent;
    }

    .btn-all:active {
        transform: scale(0.95);
        background: rgba(139, 92, 246, 0.2);
    }

    @media (min-width: 768px) {
        .slider-controls {
            display: flex;
        }
        .post-card-link {
            flex: 0 0 320px;
        }
    }
</style>