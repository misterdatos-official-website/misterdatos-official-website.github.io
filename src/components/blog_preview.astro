---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const allPosts = await getCollection("blog");

const recentPosts = allPosts
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 3);
---

<section class="blog-section" id="blog">
    <div class="blog-header">
        <h2 class="section-title">Últimas Novedades</h2>
    </div>
    <div class="posts-grid">
        {
            recentPosts.map((post) => (
                <article class="post-card">
                    {post.data.image && (
                        <div class="post-image">
                            <Image
                                src={post.data.image}
                                alt={post.data.title}
                                loading={"lazy"}
                                decoding={"async"}
                                quality={"high"}
                            />
                        </div>
                    )}
                    <div class="post-info">
                        <time datetime={post.data.date.toISOString()}>
                            {post.data.date.toLocaleDateString("es-ES", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })}
                        </time>
                        <h3>{post.data.title}</h3>
                        <p>{post.data.description}</p>
                        <a href={`/blog/${post.slug}`} class="read-more">
                            Leer artículo →
                        </a>
                    </div>
                </article>
            ))
        }
    </div>
    <div class="view-all-container">
        <a href="/blog" class="btn-all">Ver todas las publicaciones</a>
    </div>
</section>

<style>
    .blog-section {
        padding: 1rem 1rem;
        max-width: 1200px;
        margin: 0px auto;
        color: white;
        background-color: var(--color-dark);
        scroll-margin-top: 80px;
    }

    .blog-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: 1rem;
    }

    .section-title {
        font-size: 1.25rem;
        margin: 0;
        color: #a78bfa;
    }

    .section-subtitle {
        opacity: 0.75;
        margin: 0.5rem 0 0 0;
    }

    .view-all-container {
        display: flex;
        justify-content: center;
        text-align: center;
        margin-top: 1rem;
    }

    .btn-all {
        padding: 0.8rem 1.25rem;
        border: 2px solid #8b5cf6;
        border-radius: 8px;
        color: white;
        text-decoration: none;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .btn-all:hover {
        background: #8b5cf6;
        box-shadow: 0 0 15px rgba(139, 92, 246, 0.5);
    }

    .posts-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .post-card {
        background: rgba(28, 10, 27, 0.6);
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: transform 0.3s ease;
    }

    .post-card:hover {
        transform: translateY(-5px);
        border-color: #8b5cf6;
    }

    .post-image img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .post-info {
        padding: 1.5rem;
    }

    .post-info time {
        display: block;
        font-size: 0.875rem;
        color: #a78bfa;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
    }

    .post-info h3 {
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
        color: white;
    }

    .post-info p {
        font-size: 0.95rem;
        opacity: 0.9;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .read-more {
        display: inline-block;
        color: #a78bfa;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.3s ease;
    }

    .read-more:hover {
        color: #d8b4fe;
    }

    @media (min-width: 768px) {
        .posts-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>