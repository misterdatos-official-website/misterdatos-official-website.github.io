---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  url: string;
  date: Date;
  image?: any;
  category?: string;
  slug?: string;
}

const { title, description, url, date, image, category, slug } = Astro.props;
---

<article class="blog-card" data-post-slug={slug}>
  <a href={url} class="card-content">
    {
      image && (
        <div class="image-wrapper">
          <Image src={image} alt={title} loading="eager" />
        </div>
      )
    }

    <div class="text-wrapper">
      <time class="post-date">{date.toLocaleDateString("es-ES")}</time>
      <h2 class="post-title">{title}</h2>
      <p class="post-description">{description}</p>
      <span class="read-more">Leer más <i class="fas fa-arrow-right"></i></span>
      {category && <span class="category">{category}</span>}
    </div>
  </a>
</article>

<style>
  .blog-card {
    background: rgba(28, 10, 27, 0.6);
    border-radius: 16px;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 24px rgba(145, 70, 255, 0.2);
    border-color: var(--color-accent);
  }

  .card-content {
    position: relative;
    text-decoration: none;
    color: white;
    display: flex;
    flex-direction: column;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: auto;
    overflow: hidden;
  }

  .image-wrapper :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card:hover img {
    transform: scale(1.05);
  }

  .category {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: #ff8c00;
    color: var(--color-white);
    padding: 0.3rem 0.8rem;
    border-radius: 6px;
    font-weight: 800;
    font-size: 0.75rem;
    text-transform: uppercase;
  }

  .text-wrapper {
    padding: 1.5rem 2rem;
  }

  .post-date {
    color: #a29bfe;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 1rem;
  }

  .post-title {
    font-size: 1.5rem;
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .post-description {
    color: #cccccc;
    font-size: 1rem;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .read-more {
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .read-more i {
    transition: transform 0.3s ease;
  }

  .blog-card:hover .read-more i {
    transform: translateX(5px);
  }
</style>