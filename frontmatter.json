{
  "frontMatter.framework.id": "astro",
  "frontMatter.framework.startCommand": "npm run dev",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.publicFolder": {
    "path": "src/assets",
    "relative": true
  },
  "frontMatter.content.pageFolders": [
    {
      "title": "content",
      "path": "[[workspace]]/src/content"
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": false,
      "previewPath": "blog",
      "fields": [
        {
          "name": "title",
          "type": "string"
        },
        {
          "name": "slug",
          "type": "slug"
        },
        {
          "name": "draft",
          "type": "draft"
        },
        {
          "title": "date",
          "name": "date",
          "type": "datetime"
        },
        {
          "title": "description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "categories",
          "name": "categories",
          "type": "categories"
        },
        {
          "title": "keywords",
          "name": "keywords",
          "type": "tags"
        },
        {
          "title": "image",
          "name": "image",
          "type": "image"
        },
        {
          "title": "youtubeId",
          "name": "youtubeId",
          "type": "string"
        }
      ]
    }
  ],
  "frontMatter.git.enabled": true,
  "frontMatter.taxonomy.keywordsField": "keywords"
}